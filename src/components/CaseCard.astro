---
interface Props {
  title: string;
  client: string;
  problem: string;
  actions: string;
  result: string;
  metrics: string[];
}

const { title, client, problem, actions, result, metrics } = Astro.props;

function normalizeText(text: string): string {
  return text
    .split('\n')
    .map((l) => l.trim())
    .filter(Boolean)
    .join(' ');
}

// Split metric string on first ": " → { label, value }
function parseMetric(metric: string): { label: string; value: string } {
  const idx = metric.indexOf(': ');
  if (idx === -1) return { label: '', value: metric };
  return { label: metric.slice(0, idx), value: metric.slice(idx + 2) };
}
---

<article class="card fade-up overflow-hidden">
  <!-- Header -->
  <div class="flex flex-col gap-1 border-b p-6 sm:flex-row sm:items-start sm:justify-between sm:gap-4"
       style="border-color: var(--border);">
    <h3 class="text-base font-semibold leading-snug" style="color: var(--text);">
      {title}
    </h3>
    <span
      class="shrink-0 rounded-full px-3 py-0.5 text-xs"
      style="background-color: var(--surface); color: var(--text-muted);"
    >
      {client}
    </span>
  </div>

  <!-- Body: three sections -->
  <div class="divide-y p-6" style="--tw-divide-opacity: 1;">
    <style>
      .case-sections > div + div { border-top: 1px solid var(--border); padding-top: 1rem; margin-top: 1rem; }
    </style>
    <div class="case-sections flex flex-col gap-4">
      <!-- Задача -->
      <div>
        <p class="mb-1.5 text-[11px] font-semibold uppercase tracking-widest" style="color: var(--text-subtle);">
          Задача
        </p>
        <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
          {normalizeText(problem)}
        </p>
      </div>

      <!-- Что сделано -->
      <div>
        <p class="mb-1.5 text-[11px] font-semibold uppercase tracking-widest" style="color: var(--text-subtle);">
          Что сделано
        </p>
        <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
          {normalizeText(actions)}
        </p>
      </div>

      <!-- Результат -->
      <div>
        <p class="mb-1.5 text-[11px] font-semibold uppercase tracking-widest" style="color: var(--text-subtle);">
          Результат
        </p>
        <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
          {normalizeText(result)}
        </p>
      </div>
    </div>
  </div>

  <!-- Metrics -->
  {
    metrics.length > 0 && (
      <div
        class="flex flex-wrap gap-4 border-t px-6 py-5"
        style="border-color: var(--border); background-color: var(--accent-light);"
      >
        {metrics.map((m) => {
          const { label, value } = parseMetric(m);
          return (
            <div class="flex flex-col gap-0.5">
              {label && (
                <span class="text-[11px] font-medium" style="color: var(--accent);">
                  {label}
                </span>
              )}
              <span class="text-sm font-semibold leading-tight" style="color: var(--accent);">
                {value}
              </span>
            </div>
          );
        })}
      </div>
    )
  }
</article>
