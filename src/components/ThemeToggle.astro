---
---

<div class="relative" id="theme-toggle-wrapper">
  <button
    id="theme-toggle-btn"
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-label="Выбрать тему"
    class="flex h-9 w-9 items-center justify-center rounded-lg border transition-colors"
    style="border-color: var(--border); color: var(--text-muted);"
  >
    <!-- Sun — light -->
    <span id="icon-light" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4"/>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
      </svg>
    </span>
    <!-- Moon — dark -->
    <span id="icon-dark" aria-hidden="true" class="hidden">
      <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
      </svg>
    </span>
    <!-- Candle — hygge -->
    <span id="icon-hygge" aria-hidden="true" class="hidden">
      <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 21h6M12 3c0 0-3 2.5-3 6s3 6 3 6-3 2.5-3 6"/>
        <path d="M9 21v-6a3 3 0 0 1 6 0v6"/>
        <path d="M12 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"/>
      </svg>
    </span>
  </button>

  <!-- Dropdown -->
  <div
    id="theme-dropdown"
    role="listbox"
    aria-label="Выбор темы"
    class="theme-dropdown absolute right-0 z-50 mt-2 w-44 overflow-hidden rounded-xl border py-1 shadow-lg"
    style="background-color: var(--bg); border-color: var(--border);"
  >
    <button
      role="option"
      data-theme-value="light"
      class="theme-option flex w-full items-center gap-3 px-3 py-2 text-sm"
    >
      <span class="shrink-0 opacity-70" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
      </span>
      <span class="flex-1 text-left">Светлая</span>
      <span class="check-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2.5"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6 9 17l-5-5"/>
        </svg>
      </span>
    </button>

    <button
      role="option"
      data-theme-value="dark"
      class="theme-option flex w-full items-center gap-3 px-3 py-2 text-sm"
    >
      <span class="shrink-0 opacity-70" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
        </svg>
      </span>
      <span class="flex-1 text-left">Тёмная</span>
      <span class="check-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2.5"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6 9 17l-5-5"/>
        </svg>
      </span>
    </button>

    <button
      role="option"
      data-theme-value="hygge"
      class="theme-option flex w-full items-center gap-3 px-3 py-2 text-sm"
    >
      <span class="shrink-0 opacity-70" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21h6M12 3c0 0-3 2.5-3 6s3 6 3 6-3 2.5-3 6"/>
          <path d="M9 21v-6a3 3 0 0 1 6 0v6"/>
          <path d="M12 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"/>
        </svg>
      </span>
      <span class="flex-1 text-left">Hygge</span>
      <span class="check-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2.5"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6 9 17l-5-5"/>
        </svg>
      </span>
    </button>
  </div>
</div>

<style>
  .theme-dropdown {
    opacity: 0;
    transform: translateY(-6px) scale(0.97);
    pointer-events: none;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .theme-dropdown.open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .theme-option {
    cursor: pointer;
    color: var(--text-muted);
    transition: background-color 0.12s ease, color 0.12s ease;
  }

  .theme-option:hover {
    background-color: var(--surface);
    color: var(--text);
  }

  .theme-option.active {
    color: var(--accent);
  }

  .check-icon {
    opacity: 0;
    color: var(--accent);
  }

  .theme-option.active .check-icon {
    opacity: 1;
  }
</style>

<script>
  function initThemeToggle() {
    const root = document.documentElement;
    const btn = document.getElementById('theme-toggle-btn');
    const dropdown = document.getElementById('theme-dropdown');
    if (!btn || !dropdown) return;

    const iconEls: Record<string, HTMLElement | null> = {
      light: document.getElementById('icon-light'),
      dark: document.getElementById('icon-dark'),
      hygge: document.getElementById('icon-hygge'),
    };

    const options = dropdown.querySelectorAll<HTMLElement>('[data-theme-value]');

    function getTheme(): string {
      return root.getAttribute('data-theme') || 'light';
    }

    function applyTheme(theme: string) {
      root.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
      updateUI(theme);
    }

    function updateUI(theme: string) {
      Object.entries(iconEls).forEach(([key, el]) => {
        el?.classList.toggle('hidden', key !== theme);
      });
      options.forEach((opt) => {
        opt.classList.toggle('active', opt.dataset.themeValue === theme);
        opt.setAttribute('aria-selected', String(opt.dataset.themeValue === theme));
      });
    }

    function openDropdown(open: boolean) {
      dropdown.classList.toggle('open', open);
      btn.setAttribute('aria-expanded', String(open));
    }

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      openDropdown(btn.getAttribute('aria-expanded') !== 'true');
    });

    document.addEventListener('click', () => openDropdown(false));
    dropdown.addEventListener('click', (e) => e.stopPropagation());

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') openDropdown(false);
    });

    options.forEach((opt) => {
      opt.addEventListener('click', () => {
        const theme = opt.dataset.themeValue;
        if (theme) applyTheme(theme);
        openDropdown(false);
      });
    });

    updateUI(getTheme());
  }

  initThemeToggle();
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
