---

<button
  id="back-to-top"
  aria-label="Наверх"
  class="fixed bottom-6 right-6 z-40 flex h-10 w-10 items-center justify-center rounded-full text-white shadow-lg transition-all duration-300"
  style="background-color: var(--accent); opacity: 0; pointer-events: none; transform: translateY(8px);"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M18 15l-6-6-6 6" />
  </svg>
</button>

<script>
  function initBackToTop() {
    const btn = document.getElementById('back-to-top');
    if (!btn) return;

    function update() {
      const visible = window.scrollY > 400;
      btn.style.opacity = visible ? '1' : '0';
      btn.style.pointerEvents = visible ? 'auto' : 'none';
      btn.style.transform = visible ? 'translateY(0)' : 'translateY(8px)';
    }

    window.addEventListener('scroll', update, { passive: true });
    update();

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    btn.addEventListener('mouseover', () => {
      btn.style.backgroundColor = 'var(--accent-hover)';
    });
    btn.addEventListener('mouseout', () => {
      btn.style.backgroundColor = 'var(--accent)';
    });
  }

  initBackToTop();
  document.addEventListener('astro:after-swap', initBackToTop);
</script>
