---
import '../styles/global.css';
import BackToTop from '../components/BackToTop.astro';
import { getInfo } from '../lib/content-parser';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Портфолио бизнес-аналитика и бизнес-архитектора',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const info = getInfo();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: info.name,
  jobTitle: info.role,
  description: info.tagline,
  url: Astro.site?.toString() ?? 'https://alexzakharov.dev',
  email: info.contacts.email,
  sameAs: [
    `https://t.me/${info.contacts.telegram.replace('@', '')}`,
    info.contacts.linkedin,
    info.contacts.github,
  ].filter(Boolean),
};
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="ru_RU" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- JSON-LD Person schema -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Theme init (prevent flash) -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        const theme = saved || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <slot />
    <BackToTop />
  </body>

  <!-- Global scroll-reveal observer -->
  <script>
    function initScrollReveal() {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -48px 0px' }
      );

      document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
    }

    initScrollReveal();
    document.addEventListener('astro:after-swap', initScrollReveal);
  </script>
</html>
